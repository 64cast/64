# Old bookmarks / links to the previous homepage path
/home / 301
/home.html / 301

# Current stock, pre-order, and new-arrivals are now separate physical pages
# (current-stock/index.html, pre-order/index.html, new-arrivals/index.html).
# These rules only cover their own brand sub-routes (e.g. /pre-order/mini-gt) —
# no cross-section redirects between the three.
/current-stocks /current-stock/ 301
/pre-orders /pre-order/ 301
/pre-order/* /pre-order/ 200
/new-arrivals/* /new-arrivals/ 200

# Single-segment paths not otherwise matched (e.g. /mini-gt, /pop-race) are
# brand-filtered shop pages. Restricted to exactly one segment so this does
# NOT swallow "/" (the homepage) the way a bare "/*" wildcard would.
/:brand /current-stock/ 200
